PORT=5000
NODE_ENV=development
DATA_DIR=./data
MONGODB_URI=mongodb://127.0.0.1:27017/dawngas
MONGODB_DB_NAME=dawngas
JWT_SECRET=replace_with_a_secure_secret
APP_BASE_URL=http://localhost:5000
CORS_ORIGIN=http://localhost:5000
STORAGE_PROVIDER=local
BLOB_READ_WRITE_TOKEN=
EMAIL_ENABLED=false
EMAIL_PROVIDER=resend
RESEND_API_KEY=
RESEND_FROM_NAME=DawnGas
RESEND_FROM_EMAIL=
RESEND_REPLY_TO=
BACKUP_STORAGE_PATH=./data/backups
UPLOAD_STORAGE_PATH=./data/uploads
ENABLE_DEMO_TOOLS=true
ENABLE_DATA_CLEANUP=true
ENABLE_DEV_TOOLS=true

# Production values:
# NODE_ENV=production
# MONGODB_URI=mongodb+srv://PRODUCTION_CONNECTION_STRING
# MONGODB_DB_NAME=dawngas
# JWT_SECRET=GENERATED_SECURE_SECRET
# APP_BASE_URL=https://DEPLOYED_VERCEL_DOMAIN
# CORS_ORIGIN=https://DEPLOYED_VERCEL_DOMAIN
# STORAGE_PROVIDER=vercel_blob
# BLOB_READ_WRITE_TOKEN=VERCEL_MANAGED_SECRET
# EMAIL_ENABLED=true
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=RESEND_SERVER_SIDE_KEY
# RESEND_FROM_NAME=DawnGas
# RESEND_FROM_EMAIL=hello@your-verified-domain.com
# RESEND_REPLY_TO=support@your-verified-domain.com
# ENABLE_DEMO_TOOLS=false
# ENABLE_DATA_CLEANUP=false
# ENABLE_DEV_TOOLS=false
